@model QualityDocD.Models.Domain.Company
@{
    ViewData["Title"] = Model.Name;
    var stats = ViewBag.Stats as QualityDocD.Services.CompanyStats;
    var users = ViewBag.Users as IEnumerable<QualityDocD.Models.Domain.User> ?? [];
    var roles = new[] {
        ("Viewer",     "Viewer"),
        ("Reviewer",   "Reviewer"),
        ("Manager",    "Manager"),
        ("Admin",      "Admin"),
        ("SuperAdmin", "SuperAdmin"),
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">
            <i class="bi bi-building me-2 text-primary"></i>@Model.Name
            @if (Model.IsActive)
            {
                <span class="badge bg-success ms-2">Activa</span>
            }
            else
            {
                <span class="badge bg-danger ms-2">Inactiva</span>
            }
        </h2>
        <small class="text-muted">Slug: <code>@Model.Slug</code></small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">
            <i class="bi bi-pencil me-1"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (stats != null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-center py-3 shadow-sm">
                <i class="bi bi-people fs-2 text-primary"></i>
                <h3 class="fw-bold mt-2 mb-0">@stats.TotalUsers</h3>
                <div class="text-muted small">Usuarios</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center py-3 shadow-sm">
                <i class="bi bi-file-earmark-text fs-2 text-info"></i>
                <h3 class="fw-bold mt-2 mb-0">@stats.TotalDocuments</h3>
                <div class="text-muted small">Documentos</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center py-3 shadow-sm">
                <i class="bi bi-check-circle fs-2 text-success"></i>
                <h3 class="fw-bold mt-2 mb-0">@stats.ApprovedDocuments</h3>
                <div class="text-muted small">Aprobados</div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-people me-2"></i>Usuarios (@users.Count())</h6>
        <a asp-controller="Auth" asp-action="Register" class="btn btn-sm btn-primary">
            <i class="bi bi-person-plus me-1"></i> Agregar usuario
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Usuario</th>
                    <th>Correo</th>
                    <th>Área</th>
                    <th style="width:240px">Rol</th>
                    <th class="text-center">Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in users)
                {
                    <tr>
                        <td class="ps-3 fw-semibold">
                            <i class="bi bi-person me-1 text-secondary"></i>@u.Username
                        </td>
                        <td class="text-muted small">@u.Email</td>
                        <td class="text-muted small">@u.Department</td>
                        <td>
                            <form asp-action="ChangeUserRole" method="post"
                                  class="d-flex gap-2 align-items-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@u.Id" />
                                <input type="hidden" name="companyId" value="@Model.Id" />
                                <select name="role" class="form-select form-select-sm">
                                    @foreach (var (val, label) in roles)
                                    {
                                        <option value="@val" selected="@(u.Role == val)">@label</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-outline-primary"
                                        title="Guardar rol">
                                    <i class="bi bi-floppy"></i>
                                </button>
                            </form>
                        </td>
                        <td class="text-center">
                            @if (u.IsActive)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                    </tr>
                }
                @if (!users.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-people fs-3 d-block mb-2"></i>No hay usuarios aún.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
