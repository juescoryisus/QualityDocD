@model IEnumerable<QualityDocD.Models.Domain.Company>
@{
    ViewData["Title"] = "Empresas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0"><i class="bi bi-building me-2 text-primary"></i>Gestión de Empresas</h2>
        <small class="text-muted">Panel exclusivo SuperAdmin — @Model.Count() empresa(s) registrada(s)</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Nueva Empresa
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Empresa</th>
                    <th>Slug</th>
                    <th>Correo</th>
                    <th>Estado</th>
                    <th>Creada</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="fw-semibold"><i class="bi bi-building me-1 text-secondary"></i>@c.Name</td>
                        <td><code>@c.Slug</code></td>
                        <td>@c.Email</td>
                        <td>
                            @if (c.IsActive)
                            {
                                <span class="badge bg-success">Activa</span>
                            }
                            else
                            {

                                <span class="badge bg-danger">Inactiva</span>
                            }
                        </td>
                        <td class="text-muted small">@c.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                            <form asp-action="ToggleActive" asp-route-id="@c.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('@(c.IsActive ? "¿Desactivar" : "¿Activar") la empresa @c.Name?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(c.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                    <i class="bi @(c.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>