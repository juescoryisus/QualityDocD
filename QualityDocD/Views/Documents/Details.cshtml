@model QualityDocD.Models.ViewModels.DocumentDetailViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Code + " — " + Model.Title;

    // Variables para el panel de aprobaciones
    var userId = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "0");
    var isInReview = Model.Status is "UnderReview" or "UnderSecondReview";
    var myPending = Model.Approvals.FirstOrDefault(a =>
                         a.ReviewerId == userId && a.Status == "Pending");
    var canReview = myPending != null;
}

<!-- Cabecera -->
<div class="d-flex flex-wrap gap-2 justify-content-between align-items-start mb-4">
    <div>
        <div class="d-flex align-items-center gap-2 mb-1">
            <span class="badge bg-light text-dark border font-monospace fs-6">@Model.Code</span>
            <partial name="_StatusBadge" model="Model.Status" />
            @if (Model.IsPublic)
            {
                <span class="badge bg-info text-dark">
                    <i class="bi bi-globe2 me-1"></i>Público
                </span>
            }
        </div>
        <h4 class="fw-bold mb-0">@Model.Title</h4>
        <p class="text-muted small mb-0">
            v@(Model.Version) &nbsp;·&nbsp; @Model.Category &nbsp;·&nbsp; @Model.Standard
            &nbsp;·&nbsp; Creado por <strong>@Model.CreatedBy</strong>
            el @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm text-dark">
            <i class="bi bi-pencil me-1"></i>Editar
        </a>
        @if (!string.IsNullOrEmpty(Model.FileExtension))
        {
            <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success btn-sm">
                <i class="bi bi-download me-1"></i>Descargar
            </a>

            <a asp-action="Preview" asp-route-id="@Model.Id"
               class="btn btn-sm btn-outline-info ms-1">
                <i class="bi bi-eye me-1"></i>Ver archivo
            </a>
        }
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <form asp-action="MarkObsolete" asp-route-id="@Model.Id" method="post"
                  class="d-inline"
                  onsubmit="return confirm('¿Marcar este documento como Obsoleto?')">
                
                @Html.AntiForgeryToken()
                <button class="btn btn-danger btn-sm">
                    <i class="bi bi-archive me-1"></i>Obsoleto
                </button>
            </form>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('¿Eliminar este documento permanentemente? Esta acción no se puede deshacer.');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Eliminar documento
                </button>
            </form>
        }
    </div>
</div>

<div class="row g-4">
    <!-- Columna izquierda -->
    <div class="col-lg-8">

        <!-- Información -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom fw-semibold">
                <i class="bi bi-info-circle me-2 text-primary"></i>Información
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted small">Descripción</dt>
                    <dd class="col-sm-9">
                        @(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)
                    </dd>

                    <dt class="col-sm-3 text-muted small">Categoría</dt>
                    <dd class="col-sm-9">@Model.Category</dd>

                    <dt class="col-sm-3 text-muted small">Norma</dt>
                    <dd class="col-sm-9">
                        @(string.IsNullOrEmpty(Model.Standard) ? "—" : Model.Standard)
                    </dd>

                    <dt class="col-sm-3 text-muted small">Etiquetas</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.Tags))
                        {
                            @foreach (var tag in Model.Tags.Split(','))
                            {
                                <span class="badge bg-light text-secondary border me-1">
                                    @tag.Trim()
                                </span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </dd>

                    @if (!string.IsNullOrEmpty(Model.OriginalFileName))
                    {
                        <dt class="col-sm-3 text-muted small">Archivo</dt>
                        <dd class="col-sm-9">
                            <i class="bi bi-paperclip me-1"></i>
                            <strong>@Model.OriginalFileName</strong>
                            <span class="text-muted small ms-2">
                                (@Model.FileExtension &nbsp;·&nbsp;
                                @((Model.FileSizeBytes / 1024.0).ToString("N1")) KB)
                            </span>
                        </dd>
                    }

                    @if (Model.ExpiresAt.HasValue)
                    {
                        var expired = Model.ExpiresAt.Value < DateTime.UtcNow;
                        <dt class="col-sm-3 text-muted small">Vence</dt>
                        <dd class="col-sm-9 @(expired ? "text-danger fw-bold" : "")">
                            @Model.ExpiresAt.Value.ToString("dd/MM/yyyy")
                            @(expired ? " — VENCIDO" : "")
                        </dd>
                    }

                    @if (Model.ApprovedAt.HasValue)
                    {
                        <dt class="col-sm-3 text-muted small">Aprobado</dt>
                        <dd class="col-sm-9 text-success">
                            @Model.ApprovedAt.Value.ToString("dd/MM/yyyy HH:mm")
                        </dd>
                    }
                </dl>
            </div>
        </div>

        <!-- ── Enviar a revisión ──────────────────────────────────────────────
             Visible cuando: Draft (primera vez) o PendingChanges (segunda ronda) -->
        @if (Model.Status is "Draft" or "PendingChanges")
        {
            var isSecond = Model.Status == "PendingChanges";
            var borderColor = isSecond ? "border-info" : "border-warning";
            var iconColor = isSecond ? "text-info" : "text-warning";
            var btnColor = isSecond ? "btn-info" : "btn-warning text-dark";
            var label = isSecond ? "Enviar a 2ª Revisión" : "Enviar a Revisión";

            <div class="card border-0 shadow-sm border-start border-4 @borderColor mb-4">
                <div class="card-header bg-white border-bottom fw-semibold">
                    <i class="bi bi-send me-2 @iconColor"></i>@label
                    @if (isSecond)
                    {
                        <span class="badge bg-info text-dark ms-2">Segunda ronda</span>
                    }
                </div>
                <div class="card-body">
                    <form asp-action="SubmitForReview" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="DocumentId" value="@Model.Id" />
                        <label class="form-label small fw-semibold">Seleccionar Revisores</label>
                        @if (Model.AvailableReviewers.Any())
                        {
                            <div class="row g-2 mb-3">
                                @foreach (var r in Model.AvailableReviewers)
                                {
                                    <div class="col-md-6">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   name="ReviewerIds" value="@r.Id"
                                                   id="rev_@r.Id" />
                                            <label class="form-check-label small" for="rev_@r.Id">
                                                <strong>@r.Username</strong>
                                                <span class="text-muted">(@r.Department)</span>
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small">No hay revisores disponibles.</p>
                        }
                        <button type="submit" class="btn @btnColor btn-sm">
                            <i class="bi bi-send me-1"></i>@label
                        </button>
                    </form>
                </div>
            </div>
        }

        <!-- ── Panel de Aprobaciones ─────────────────────────────────────────
             Muestra la línea de tiempo de revisores + acciones del revisor actual -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom fw-semibold d-flex align-items-center gap-2">
                <i class="bi bi-check2-circle text-primary"></i>Flujo de Aprobación
                <partial name="_StatusBadge" model="Model.Status" />
            </div>
            <div class="card-body">

                @* Línea de tiempo de revisores *@
                @if (Model.Approvals.Any())
                {
                    <ol class="list-group list-group-numbered mb-3">
                        @foreach (var a in Model.Approvals.OrderBy(x => x.Order))
                        {
                            var (badgeCls, badgeIcon, badgeLbl) = a.Status switch
                            {
                                "Approved" => ("success", "bi-check-circle-fill", "Aprobado"),
                                "Rejected" => ("danger", "bi-x-circle-fill", "Rechazado"),
                                "RequestChanges" => ("info", "bi-pencil-fill", "Solicita cambios"),
                                _ => ("secondary", "bi-hourglass", "Pendiente"),
                            };
                            <li class="list-group-item d-flex align-items-start gap-3 border-0 px-0">
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between">
                                        <strong>@a.ReviewerName</strong>
                                        <span class="badge bg-@badgeCls">
                                            <i class="bi @badgeIcon me-1"></i>@badgeLbl
                                        </span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(a.Comments))
                                    {
                                        <p class="text-muted small mb-0 mt-1">
                                            <i class="bi bi-chat-left-quote me-1"></i>@a.Comments
                                        </p>
                                    }
                                    @if (a.ReviewedAt.HasValue)
                                    {
                                        <p class="text-muted small mb-0">
                                            <i class="bi bi-clock me-1"></i>
                                            @a.ReviewedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                        </p>
                                    }
                                </div>
                            </li>
                        }
                    </ol>
                }
                else
                {
                    <p class="text-muted small mb-3">No hay revisores asignados aún.</p>
                }

                @* Acciones: solo si el documento está en revisión y el usuario tiene una aprobación pendiente *@
                @if (isInReview && canReview && myPending != null)
                {
                    <hr class="my-3" />
                    <p class="small fw-semibold mb-2">Tu revisión:</p>
                    <div class="d-flex flex-column gap-2">

                        @* Aprobar *@
                        <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="input-group input-group-sm">
                                <input type="text" name="comments" class="form-control"
                                       placeholder="Comentarios (opcional)" maxlength="500" />
                                <button class="btn btn-success" type="submit">
                                    <i class="bi bi-check-lg me-1"></i>Aprobar
                                </button>
                            </div>
                        </form>

                        @* Solicitar cambios *@
                        <form asp-action="RequestChanges" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="input-group input-group-sm">
                                <input type="text" name="comments" class="form-control"
                                       placeholder="Describe los cambios requeridos (obligatorio)"
                                       required maxlength="500" />
                                <button class="btn btn-outline-info" type="submit">
                                    <i class="bi bi-pencil me-1"></i>Solicitar Cambios
                                </button>
                            </div>
                        </form>

                        @* Rechazar *@
                        <form asp-action="Reject" asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('¿Rechazar definitivamente este documento? Esta acción no se puede deshacer.')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="input-group input-group-sm">
                                <input type="text" name="comments" class="form-control"
                                       placeholder="Motivo del rechazo (obligatorio)"
                                       required maxlength="500" />
                                <button class="btn btn-outline-danger" type="submit">
                                    <i class="bi bi-x-lg me-1"></i>Rechazar
                                </button>
                            </div>
                        </form>
                    </div>
                }

                @* Cambios pendientes — aviso al autor *@
                @if (Model.Status == "PendingChanges")
                {
                    var changeRequest = Model.Approvals
                        .Where(a => a.Status == "RequestChanges")
                        .OrderByDescending(a => a.ReviewedAt)
                        .FirstOrDefault();

                    <div class="alert alert-info d-flex gap-2 mt-3 mb-0">
                        <i class="bi bi-pencil-fill fs-5 flex-shrink-0"></i>
                        <div>
                            <strong>Se han solicitado cambios</strong>
                            @if (changeRequest != null && !string.IsNullOrEmpty(changeRequest.Comments))
                            {
                                <p class="mb-1 mt-1">@changeRequest.Comments</p>
                                <p class="small mb-0">— @changeRequest.ReviewerName</p>
                            }
                            <p class="small mb-0 mt-2">
                                Realiza los cambios necesarios y vuelve a enviar el documento a revisión.
                            </p>
                        </div>
                    </div>
                }

                @* Rechazado — aviso al autor *@
                @if (Model.Status == "Rejected")
                {
                    var rejection = Model.Approvals
                        .Where(a => a.Status == "Rejected")
                        .OrderByDescending(a => a.ReviewedAt)
                        .FirstOrDefault();

                    <div class="alert alert-danger d-flex gap-2 mt-3 mb-0">
                        <i class="bi bi-x-circle-fill fs-5 flex-shrink-0"></i>
                        <div>
                            <strong>Documento rechazado</strong>
                            @if (rejection != null && !string.IsNullOrEmpty(rejection.Comments))
                            {
                                <p class="mb-1 mt-1">@rejection.Comments</p>
                                <p class="small mb-0">— @rejection.ReviewerName</p>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>

    </div>

    <!-- Columna derecha -->
    <div class="col-lg-4">

        <!-- Historial -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom fw-semibold small">
                <i class="bi bi-clock-history me-2 text-secondary"></i>Historial
            </div>
            <ul class="list-group list-group-flush"
                style="max-height:320px;overflow-y:auto">
                @foreach (var log in Model.AuditLogs)
                {
                    <li class="list-group-item py-2">
                        <div class="d-flex justify-content-between">
                            <span class="small fw-semibold">@log.Action</span>
                            <span class="text-muted" style="font-size:.72rem">
                                @log.CreatedAt.ToString("dd/MM HH:mm")
                            </span>
                        </div>
                        <div class="text-muted" style="font-size:.75rem">
                            @(log.Username ?? "Sistema")
                            @if (log.OldValue != null || log.NewValue != null)
                            {
                                <span>· @log.OldValue → @log.NewValue</span>
                            }
                        </div>
                    </li>
                }
                @if (!Model.AuditLogs.Any())
                {
                    <li class="list-group-item text-muted small text-center py-3">
                        Sin historial
                    </li>
                }
            </ul>
        </div>

    </div>
</div>
