@model QualityDocD.Models.ViewModels.DocumentIndexViewModel
@{
    ViewData["Title"] = "Documentos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-folder2-open me-2 text-primary"></i>Gestión de Documentos
    </h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Nuevo Documento
    </a>
</div>

<!-- Filtros -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <input type="hidden" name="page" value="1" />
            <div class="col-md-4">
                <label class="form-label small fw-semibold mb-1">Buscar</label>
                <input name="search" value="@Model.SearchQuery" class="form-control form-control-sm"
                       placeholder="Código, título, descripción..." />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Estado</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">— Todos —</option>
                    @foreach (var st in new[] {
                        ("Draft",             "Borrador"),
                        ("UnderReview",       "En Revisión"),
                        ("PendingChanges",    "Cambios Pendientes"),
                        ("UnderSecondReview", "2ª Revisión"),
                        ("Approved",          "Aprobado"),
                        ("Rejected",          "Rechazado"),
                        ("Obsolete",          "Obsoleto") })
                    {
                        <option value="@st.Item1" selected="@(Model.FilterStatus == st.Item1)">
                            @st.Item2
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Categoría</label>
                <select name="category" class="form-select form-select-sm">
                    <option value="">— Todas —</option>
                    @foreach (var cat in new[] { "Manual", "Procedure", "Record", "Audit", "Other" })
                    {
                        <option value="@cat" selected="@(Model.FilterCategory == cat)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Contadores rápidos por estado -->
<div class="d-flex flex-wrap gap-2 mb-3">
    @{
        var allStatuses = new[] {
            ("",             "Todos",              "primary"),
            ("Draft",        "Borradores",         "secondary"),
            ("UnderReview",  "En Revisión",        "warning"),
            ("PendingChanges","Cambios Pend.",     "info"),
            ("UnderSecondReview","2ª Revisión",    "primary"),
            ("Approved",     "Aprobados",          "success"),
            ("Rejected",     "Rechazados",         "danger"),
            ("Obsolete",     "Obsoletos",          "dark"),
        };
    }
    @foreach (var (key, label, color) in allStatuses)
    {
        var count = key == "" ? Model.TotalCount : Model.StatusCounts.GetValueOrDefault(key, 0);
        var active = (Model.FilterStatus ?? "") == key;
        if (count == 0 && key != "" && !active) { continue; }
        <a asp-action="Index" asp-route-status="@key" asp-route-category="@Model.FilterCategory"
           asp-route-search="@Model.SearchQuery" asp-route-page="1"
           class="badge fs-6 text-decoration-none
            @(active ? $"bg-{color}" : "bg-light text-dark border")">
            @label (@count)
        </a>
    }
</div>

<!-- Tabla -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-muted small ps-3" style="width:50px">ID</th>
                        <th style="width:110px">Código</th>
                        <th>Título</th>
                        <th>Categoría</th>
                        <th>Norma</th>
                        <th class="text-center" style="width:50px">Ver.</th>
                        <th>Estado</th>
                        <th>Archivo</th>
                        <th>Creado por</th>
                        <th>Fecha</th>
                        <th class="text-end pe-3">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Documents.Any())
                    {
                        <tr>
                            <td colspan="11" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No hay documentos con los filtros seleccionados.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model.Documents)
                    {
                        <tr>
                            <td class="ps-3 text-muted small font-monospace">@item.Id</td>
                            <td>
                                <span class="badge bg-light text-dark border font-monospace">@item.Code</span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="text-decoration-none fw-semibold text-dark">
                                    @item.Title
                                </a>
                                @if (item.IsPublic)
                                {
                                    <i class="bi bi-globe2 ms-1 text-info small" title="Público"></i>
                                }
                            </td>
                            <td class="small text-muted">@item.Category</td>
                            <td class="small text-muted">@item.Standard</td>
                            <td class="text-center small">v@(item.Version)</td>
                            <td>@Html.Partial("_StatusBadge", item.Status)</td>
                            <td class="small text-muted">
                                @if (!string.IsNullOrEmpty(item.FileExtension))
                                {
                                    <span class="font-monospace">@item.FileExtension</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="small">@item.CreatedBy</td>
                            <td class="small text-muted text-nowrap">
                                @item.CreatedAt.ToString("dd/MM/yyyy")
                            </td>
                            <td class="text-end pe-3">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-outline-primary btn-sm" title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if ((item.Status is "Draft" or "PendingChanges") && !User.IsInRole("Viewer"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-outline-warning btn-sm" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Paginación -->
@if (Model.TotalPages > 1)
{
    <nav class="d-flex justify-content-between align-items-center mt-3">
        <small class="text-muted">
            Mostrando @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount))
            de @Model.TotalCount documentos
        </small>
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.Page - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-status="@Model.FilterStatus"
                   asp-route-category="@Model.FilterCategory"
                   asp-route-search="@Model.SearchQuery">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-status="@Model.FilterStatus"
                       asp-route-category="@Model.FilterCategory"
                       asp-route-search="@Model.SearchQuery">@i</a>
                </li>
            }

            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(Model.Page + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-status="@Model.FilterStatus"
                   asp-route-category="@Model.FilterCategory"
                   asp-route-search="@Model.SearchQuery">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}

