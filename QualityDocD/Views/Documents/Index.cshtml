@model QualityDocD.Models.ViewModels.DocumentIndexViewModel
@{ ViewData["Title"] = "Documentos"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-folder2-open me-2 text-primary"></i>Gestión de Documentos
    </h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Nuevo Documento
    </a>
</div>

<!-- Filtros -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold mb-1">Buscar</label>
                <input name="search" value="@Model.SearchQuery" class="form-control form-control-sm"
                       placeholder="Código, título, descripción..." />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Estado</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">— Todos —</option>
                    @foreach (var st in new[] {
                        ("Draft","Borrador"), ("UnderReview","En Revisión"),
                        ("Approved","Aprobado"), ("Obsolete","Obsoleto") })
                    {
                        <option value="@st.Item1" selected="@(Model.FilterStatus == st.Item1)">
                            @st.Item2
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Categoría</label>
                <select name="category" class="form-select form-select-sm">
                    <option value="">— Todas —</option>
                    @foreach (var cat in new[] { "Manual","Procedure","Record","Audit","Other" })
                    {
                        <option value="@cat" selected="@(Model.FilterCategory == cat)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Contadores rápidos -->
<div class="d-flex flex-wrap gap-2 mb-3">
    @foreach (var (label, key, color) in new[] {
        ("Todos","","primary"), ("Borradores","Draft","secondary"),
        ("En Revisión","UnderReview","warning"), ("Aprobados","Approved","success"),
        ("Obsoletos","Obsolete","danger") })
    {
        var count  = key == "" ? Model.Documents.Count : Model.StatusCounts.GetValueOrDefault(key, 0);
        var active = (Model.FilterStatus ?? "") == key;
        <a asp-action="Index" asp-route-status="@key" asp-route-category="@Model.FilterCategory"
           class="badge fs-6 text-decoration-none
                  @(active ? $"bg-{color}" : "bg-light text-dark border")">
            @label (@count)
        </a>
    }
</div>

<!-- Tabla -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:100px">Código</th>
                        <th>Título</th>
                        <th>Categoría</th>
                        <th>Norma</th>
                        <th class="text-center">Ver.</th>
                        <th>Estado</th>
                        <th>Archivo</th>
                        <th>Creado por</th>
                        <th>Fecha</th>
                        <th style="width:110px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.Documents)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-light text-dark border font-monospace">
                                    @doc.Code
                                </span>
                            </td>
                            <td class="fw-semibold">
                                <a asp-action="Details" asp-route-id="@doc.Id"
                                   class="text-decoration-none text-dark">@doc.Title</a>
                                @if (doc.IsPublic)
                                {
                                    <span class="badge bg-info text-dark ms-1"
                                          title="Público" style="font-size:.65rem">
                                        <i class="bi bi-globe2"></i>
                                    </span>
                                }
                            </td>
                            <td><span class="text-muted small">@doc.Category</span></td>
                            <td><span class="text-muted small">@doc.Standard</span></td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">v@doc.Version</span>
                            </td>
                            <td>@Html.Partial("_StatusBadge", doc.Status)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(doc.FileExtension))
                                {
                                    <span class="badge bg-light text-secondary border small text-uppercase">
                                        @doc.FileExtension.TrimStart('.')
                                    </span>
                                }
                            </td>
                            <td class="text-muted small">@doc.CreatedBy</td>
                            <td class="text-muted small text-nowrap">
                                @doc.CreatedAt.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@doc.Id"
                                       class="btn btn-outline-primary" title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@doc.Id"
                                       class="btn btn-outline-secondary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (!string.IsNullOrEmpty(doc.FileExtension))
                                    {
                                        <a asp-action="Download" asp-route-id="@doc.Id"
                                           class="btn btn-outline-success" title="Descargar">
                                            <i class="bi bi-download"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Documents.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                No se encontraron documentos con los filtros actuales.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
