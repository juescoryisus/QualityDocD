@model QualityDocD.Models.ViewModels.FilePreviewViewModel
@{
    ViewData["Title"] = $"Vista previa — {Model.Title}";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a asp-action="Details" asp-route-id="@Model.DocumentId"
           class="btn btn-sm btn-outline-secondary me-2">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
        <span class="fw-semibold">@Model.Title</span>
        <span class="text-muted small ms-2">@Model.OriginalFileName</span>
    </div>
    <a asp-action="Download" asp-route-id="@Model.DocumentId"
       class="btn btn-sm btn-outline-primary">
        <i class="bi bi-download me-1"></i>Descargar
    </a>
</div>

@if (Model.PreviewType == "pdf")
{
    <div class="border rounded overflow-hidden" style="height: 82vh;">
        <iframe src="/Documents/ViewFile/@Model.DocumentId"
                width="100%" height="100%"
                style="border:none;"
                title="@Model.OriginalFileName">
            <p>
                Tu navegador no puede mostrar el PDF.
                <a asp-action="Download" asp-route-id="@Model.DocumentId">Descárgalo aquí.</a>
            </p>
        </iframe>
    </div>
}
else if (Model.PreviewType == "text")
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light py-2">
            <i class="bi bi-file-text me-1"></i>
            <span class="small text-muted">@Model.OriginalFileName</span>
        </div>
        <div class="card-body p-0">
            <pre class="m-0 p-4"
                 style="max-height:80vh; overflow-y:auto;
            font-size:.85rem; white-space:pre-wrap;
            word-break:break-word; background:#1e1e1e; color:#d4d4d4;">@Model.TextContent</pre>
        </div>
    </div>
}
else if (Model.PreviewType == "docx")
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light py-2">
            <i class="bi bi-file-word me-1 text-primary"></i>
            <span class="small text-muted">@Model.OriginalFileName</span>
        </div>
        <div class="card-body" style="max-height:80vh; overflow-y:auto;">
            <style>
                        .docx-preview {
                            font-family: 'Segoe UI', sans-serif;
                            max-width: 860px;
                            margin: 0 auto;
                        }

                        .docx-para {
                            margin-bottom: .5rem;
                            line-height: 1.7;
                        }

                        .docx-table {
                            margin: 1rem 0;
                        }
            </style>
            @Html.Raw(Model.HtmlContent)
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-file-earmark fs-1 text-muted d-block mb-3"></i>
            <p class="text-muted">Vista previa no disponible para <strong>@Model.FileExtension</strong></p>
            <a asp-action="Download" asp-route-id="@Model.DocumentId"
               class="btn btn-primary">
                <i class="bi bi-download me-1"></i>Descargar archivo
            </a>
        </div>
    </div>
}