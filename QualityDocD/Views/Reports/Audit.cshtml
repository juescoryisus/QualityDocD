@model QualityDocD.Models.ViewModels.AuditReportViewModel
@{
    ViewData["Title"] = "Log de Auditoría";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-journal-text me-2 text-secondary"></i>Log de Auditoría
    </h4>
    <span class="badge bg-secondary fs-6">@Model.TotalCount registros</span>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Fecha/Hora</th>
                        <th>Acción</th>
                        <th>Documento</th>
                        <th>Usuario</th>
                        <th>Antes</th>
                        <th>Después</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.Logs)
                    {
                        <tr>
                            <td class="text-muted small text-nowrap">
                                @log.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td>
                                @{
                                    var (ic, cls) = log.Action switch
                                    {
                                        "Created" => ("bi-file-plus", "text-success"),
                                        "Updated" => ("bi-pencil", "text-warning"),
                                        "StatusChange" => ("bi-arrow-left-right", "text-primary"),
                                        "Downloaded" => ("bi-download", "text-info"),
                                        _ => ("bi-circle", "text-muted"),
                                    };
                                }
                                <i class="bi @ic @cls me-1"></i>
                                <span class="small">@log.Action</span>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border font-monospace small">
                                    @log.DocumentCode
                                </span>
                                <span class="small text-muted ms-1">@log.DocumentTitle</span>
                            </td>
                            <td class="small">@(log.Username ?? "—")</td>
                            <td class="small text-muted">@(log.OldValue ?? "—")</td>
                            <td class="small">@(log.NewValue ?? "—")</td>
                            <td class="small text-muted">@(log.IpAddress ?? "—")</td>
                        </tr>
                    }
                    @if (!Model.Logs.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Sin registros de auditoría
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Audit"
                       asp-route-page="@p"
                       asp-route-pageSize="@Model.PageSize">@p</a>
                </li>
            }
        </ul>
    </nav>
}