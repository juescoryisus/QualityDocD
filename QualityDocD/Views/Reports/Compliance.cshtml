@model QualityDocD.Models.ViewModels.ComplianceReportViewModel
@{
    ViewData["Title"] = "Reporte de Cumplimiento";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-clipboard-check me-2 text-success"></i>Reporte de Cumplimiento
    </h4>
    <div class="d-flex gap-2">
        <span class="badge bg-success fs-6">@Model.TotalApproved Aprobados</span>
        <span class="badge bg-secondary fs-6">@Model.TotalDocuments Total</span>
    </div>
</div>

<!-- Filtro de fechas -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold mb-1">Desde</label>
                <input type="date" name="dateFrom" value="@Model.DateFrom"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold mb-1">Hasta</label>
                <input type="date" name="dateTo" value="@Model.DateTo"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success btn-sm w-100">
                    <i class="bi bi-funnel me-1"></i>Aplicar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Categoría</th>
                        <th>Norma</th>
                        <th class="text-success text-center">Aprobados</th>
                        <th class="text-secondary text-center">Borradores</th>
                        <th class="text-warning text-center">En Revisión</th>
                        <th class="text-danger text-center">Obsoletos</th>
                        <th class="text-center">Total</th>
                        <th class="text-center">% Cumplimiento</th>
                        <th>Última Aprobación</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        var pct = row.Total > 0 ? (row.Approved * 100.0 / row.Total) : 0;
                        var barColor = pct >= 80 ? "bg-success" : pct >= 50 ? "bg-warning" : "bg-danger";
                        <tr>
                            <td class="fw-semibold">@row.Category</td>
                            <td class="text-muted small">@row.Standard</td>
                            <td class="text-center">
                                <span class="badge bg-success">@row.Approved</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@row.Draft</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-warning text-dark">@row.UnderReview</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-danger">@row.Obsolete</span>
                            </td>
                            <td class="text-center fw-bold">@row.Total</td>
                            <td style="min-width:130px">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:8px">
                                        <div class="progress-bar @barColor"
                                             style="width:@pct.ToString("F0")%"></div>
                                    </div>
                                    <span class="small fw-semibold">@pct.ToString("F0")%</span>
                                </div>
                            </td>
                            <td class="text-muted small">
                                @(row.LastApproved.HasValue
                                    ? row.LastApproved.Value.ToString("dd/MM/yyyy") : "—")
                            </td>
                        </tr>
                    }
                    @if (!Model.Rows.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">Sin datos</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>