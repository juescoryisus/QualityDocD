<!DOCTYPE html>
<html lang="es" id="htmlRoot" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — QualityDoc</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
            (function () {
                var saved = localStorage.getItem('theme') || 'light';
                document.getElementById('htmlRoot').setAttribute('data-bs-theme', saved);
            })();
    </script>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-file-earmark-check-fill me-2"></i>QualityDoc
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Documents" asp-action="Index">
                                <i class="bi bi-folder2-open me-1"></i>Documentos
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-graph-up me-1"></i>Reportes
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Reports" asp-action="Compliance">
                                        <i class="bi bi-clipboard-check me-2"></i>Cumplimiento
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Reports" asp-action="Audit">
                                        <i class="bi bi-journal-text me-2"></i>Auditoría
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Reports" asp-action="Search">
                                        <i class="bi bi-search me-2"></i>Búsqueda Avanzada
                                    </a>
                                </li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" href="http://localhost:8080" target="_blank">
                                            <i class="bi bi-database-check me-2"></i>Portal Auditoría
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i>Registrar Usuario
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-building me-1"></i>Empresas
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Companies" asp-action="Index">
                                            <i class="bi bi-list-ul me-2"></i>Ver todas
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Companies" asp-action="Create">
                                            <i class="bi bi-plus-circle me-2"></i>Nueva empresa
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    }
                    }
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">

                    <li class="nav-item me-2">
                        <button id="darkModeToggle" class="btn btn-sm btn-outline-light" title="Cambiar tema">
                            <i id="themeIcon" class="bi bi-moon-fill"></i>
                        </button>
                    </li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>
                                @User.Identity.Name
                                <span class="badge bg-warning text-dark ms-1" style="font-size:.65rem">
                                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                </span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Ingresar
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container-fluid px-4 py-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="border-top py-3 mt-4 text-muted small text-center">
        QualityDoc &copy; @DateTime.Now.Year &nbsp;|&nbsp;
        .NET 9 &nbsp;+&nbsp; SQL Server &nbsp;+&nbsp; PostgreSQL &nbsp;+&nbsp; MongoDB
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
        var root   = document.getElementById('htmlRoot');
        var btn    = document.getElementById('darkModeToggle');
        var icon   = document.getElementById('themeIcon');
        var saved  = localStorage.getItem('theme') || 'light';

        function applyTheme(theme) {
        root.setAttribute('data-bs-theme', theme);
        icon.className = theme === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
        localStorage.setItem('theme', theme);
        }

        applyTheme(saved);

        btn.addEventListener('click', function () {
        var current = root.getAttribute('data-bs-theme');
        applyTheme(current === 'dark' ? 'light' : 'dark');
        });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>