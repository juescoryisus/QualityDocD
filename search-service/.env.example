# ── search-service — variables de entorno ─────────────────────────────────────
# Copia este archivo como .env y ajusta los valores para tu entorno local

# Puerto donde escucha el servicio (default: 3001)
PORT=3001

# Conexión MongoDB
# Desarrollo local sin Docker (MongoDB instalado directamente):
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=qualitydoc_meta
# Dejar vacíos si no usas autenticación en desarrollo local:
MONGO_USER=
MONGO_PASSWORD=

# Con Docker (usar el nombre del contenedor como host):
# MONGO_HOST=mongodb
# MONGO_USER=qualitydoc
# MONGO_PASSWORD=QualityDoc_Mongo_2026!
